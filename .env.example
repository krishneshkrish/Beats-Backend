# Beats Backend — Environment Config
# Copy this to .env and fill in values

# App
APP_ENV=development
APP_PORT=8000
SECRET_KEY=beats-secret-change-in-prod

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/beats.db

# CORS — comma separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ML Model paths
MODEL_PATH=./data/models/recommender.pkl
FEATURE_STORE_PATH=./data/features/

# Optional: set to 1 to seed mock data on startup
SEED_MOCK_DATA=1
